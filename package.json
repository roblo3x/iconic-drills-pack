{
  "name": "iconic-drills-pack",
  "version": "0.1.0-alpha.1",
  "description": "A rough, hand-drawn SVG illustration and emoji pack by Roman Kuzhel.",
  "author": "Roman Kuzhel, Kyrgyzstan",
  "type": "module",
  "sideEffects": false,
  "license": "(MIT AND CC-BY-4.0 AND Unicode-3.0)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roblo3x/iconic-drills-pack.git"
  },
  "homepage": "https://roblo3x.github.io/iconic-drills-pack/",
  "bugs": "https://github.com/roblo3x/iconic-drills-pack/issues",
  "keywords": [
    "emoji",
    "icons",
    "illustrations",
    "svg",
    "ddrills",
    "custom-emoji",
    "hand-drawn",
    "icon-pack",
    "cc-by"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./data": "./dist/data/icons.json",
    "./illustration/*": "./dist/illustration/*",
    "./emoji-svg/*": "./dist/emoji-svg/*",
    "./emoji-png/128/*": "./dist/emoji-png/128/*",
    "./emoji-png/256/*": "./dist/emoji-png/256/*",
    "./emoji-png/512/*": "./dist/emoji-png/512/*"
  },
  "files": [
    "dist",
    "README.md",
    "ATTRIBUTION.md",
    "LICENSE-CODE",
    "LICENSE-ICONS",
    "LICENSE-UNICODE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "bootstrap": "node scripts/bootstrap-approved.mjs",
    "smooth": "node scripts/smooth-masters.mjs",
    "build": "node scripts/build.mjs && node scripts/build-preview.mjs",
    "preview": "node scripts/build-preview.mjs",
    "site:build": "node scripts/build-site.mjs",
    "site:validate": "node scripts/validate-site.mjs",
    "site:test": "npm run site:build && npm run site:validate",
    "validate": "node scripts/validate.mjs",
    "test": "npm run build && npm run validate && node --test",
    "pack:check": "npm pack --dry-run"
  },
  "devDependencies": {
    "paper": "^0.12.18",
    "sharp": "^0.34.3"
  },
  "engines": {
    "node": ">=20"
  }
}
